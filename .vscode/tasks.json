{
  "tasks": [
    {
      "label": "Initial Setup",
      "type": "shell",
      "command": "npm install",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": "none"
    },
    {
      "label": "Validate: Ruff Lint",
      "type": "shell",
      "command": "mkdir -Force .reports; uv run --with ruff ruff check --config .validate/pyproject.toml --exit-zero . | tee .reports/ruff_lint.txt",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": "build"
    },
    {
      "label": "Validate: Ruff Format Check",
      "type": "shell",
      "command": "mkdir -Force .reports; uv run --with ruff ruff format --config .validate/pyproject.toml --check . | tee .reports/ruff_format_status.txt; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": "build"
    },
    {
      "label": "Validate: Prettier Check",
      "type": "shell",
      "command": "mkdir -Force .reports; npx prettier --config .validate/.prettierrc.json --check \"**/*.md\" \"**/*.json\" \"**/*.yaml\" \"!.validate/**\" \"!node_modules/**\" | tee .reports/prettier_check.txt; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": "build"
    },
    {
      "label": "Validate: Markdown Style",
      "type": "shell",
      "command": "mkdir -Force .reports; npx --package=markdownlint-cli markdownlint --config .validate/.markdownlint.json --ignore-path .gitignore \"**/*.md\" 2>&1 | tee .reports/markdown_lint.txt; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": "build"
    },
    {
      "label": "Validate: YAML Style",
      "type": "shell",
      "command": "mkdir -Force .reports; uv run --with yamllint yamllint -c .validate/.yamllint . | tee .reports/yaml_lint.txt; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": "build"
    },
    {
      "label": "Validate: Codespell",
      "type": "shell",
      "command": "mkdir -Force .reports; uv run --with codespell codespell --skip=\"*.ffs_*,*.ffs_db,*.ffs_lock,.git,.venv,.ruff_cache,.reports,*.log,*.code-workspace,node_modules,.validate\" --ignore-words-list=\"hass\" . | tee .reports/codespell.txt; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": "build"
    },
    {
      "label": "Validate All",
      "type": "shell",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Validate: Ruff Lint",
        "Validate: Ruff Format Check",
        "Validate: Prettier Check",
        "Validate: Markdown Style",
        "Validate: YAML Style",
        "Validate: Codespell"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Format: Apply Ruff Lint Fix",
      "type": "shell",
      "command": "uv run --with ruff ruff check --config .validate/pyproject.toml --fix .; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Format: Apply Ruff Format",
      "type": "shell",
      "command": "uv run --with ruff ruff format --config .validate/pyproject.toml .; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Format: Apply Prettier",
      "type": "shell",
      "command": "npx prettier --config .validate/.prettierrc.json --write \"**/*.md\" \"**/*.json\" \"**/*.yaml\" \"!.validate/**\" \"!node_modules/**\"; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Format: Apply Codespell",
      "type": "shell",
      "command": "uv run --with codespell codespell -w --skip=\"*.ffs_*,*.ffs_db,*.ffs_lock,.git,.venv,.ruff_cache,.reports,*.log,*.code-workspace,node_modules,.validate\" --ignore-words-list=\"hass\" .; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Format: Apply Markdownlint",
      "type": "shell",
      "command": "npx --package=markdownlint-cli markdownlint --config .validate/.markdownlint.json --ignore-path .gitignore --fix \"**/*.md\"; exit 0",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Format All",
      "type": "shell",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Format: Apply Ruff Lint Fix",
        "Format: Apply Ruff Format",
        "Format: Apply Prettier",
        "Format: Apply Codespell",
        "Format: Apply Markdownlint"
      ],
      "problemMatcher": [],
      "group": "none",
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ],
  "version": "2.0.0"
}
